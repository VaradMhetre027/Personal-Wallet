# ── Application ──
APP_NAME=Personal Wallet
APP_VERSION=0.1.0
DEBUG=true

# ── Security ──
# IMPORTANT: Generate a real secret → python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-generate-a-real-secret-key-with-64-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──
DATABASE_URL=sqlite:///./wallet.db

# ── Rate Limiting ──
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
